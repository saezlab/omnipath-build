# Production environment - pinned to a specific data version
# Set DATA_VERSION when deploying:
#   make deploy-prod VERSION=v-20260225-071916
# Or set DATA_DIR directly here:
DATA_DIR=../data/releases/v-CHANGE_ME
MEILISEARCH_API_KEY=change-me
MEILI_ENV=production
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_DOMAIN=omnipath.org
GOOGLE_GENERATIVE_AI_API_KEY=change-me
MEILISEARCH_PORT=7700
MEILISEARCH_VOLUME_NAME=omnipath-prod-meilisearch
ONTOLOGY_CACHE_VOLUME_NAME=omnipath-prod-ontology-cache
