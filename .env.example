# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5436
DATABASE_URL=postgresql://postgres:postgres@localhost:5436/metabo

# Meilisearch (required for docker compose and make targets)
MEILI_MASTER_KEY=your-secure-key-here

